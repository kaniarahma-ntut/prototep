{
    "version": 2,
    "plugins": [],
    "functions": {
        "api/*.php": { "runtime": "vercel-php@0.7.5" },
        "index.php": { "runtime": "vercel-php@0.7.5" }
    },
    "routes": [
        {
            "src": "/build/(.*)",
            "dest": "/build/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/index.php"
        }
    ]
}